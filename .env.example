# Copy this file to .env (gitignored) before running npm run test:e2e.
#
# ALLOWED_TOKENS_LIST is the comma-separated list of managed access tokens
# accepted by /api/generate-image. The value below is the test token used by
# the throttle spec (tests/generate-image.spec.ts) — it is not a real secret.
ALLOWED_TOKENS_LIST="abc,daycare-club"

# Real Gemini API key — only needed if you want the AI generation flow to
# actually call Gemini during local testing. Tests that exercise generation use
# BYOK (apiKey field) or mock the endpoint, so this is optional for the E2E suite.
# GEMINI_API_KEY=
GEMINI_API_KEY=replace
ADMIN_ACCESS_TOKEN=replace
