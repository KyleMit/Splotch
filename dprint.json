{
  "lineWidth": 100,
  "indentWidth": 2,
  "markdown": {
    "textWrap": "always",
    "emphasisKind": "asterisks",
    "strongKind": "asterisks",
    "unorderedListKind": "asterisks"
  },
  "typescript": {
    "quoteStyle": "preferSingle"
  },
  "includes": ["**/*.md"],
  "excludes": [
    "**/node_modules",
    "**/.svelte-kit",
    "**/.netlify",
    "**/.gradle",
    ".agents/skills",
    ".claude/skills",
    "AGENTS.md",
    "CLAUDE.md",
    "android/AGENTS.md",
    "android/CLAUDE.md",
    "docs/handoff/AGENTS.md",
    "docs/handoff/CLAUDE.md",
    "scripts/AGENTS.md",
    "scripts/CLAUDE.md",
    "tools/asset-gen/AGENTS.md",
    "tools/asset-gen/CLAUDE.md",
    "web/src/AGENTS.md",
    "web/src/CLAUDE.md",
    "web/tests/AGENTS.md",
    "web/tests/CLAUDE.md",
    "web/build",
    "android/**/build",
    "ios/**/build"
  ],
  "plugins": [
    "node_modules/@dprint/markdown/plugin.wasm",
    "node_modules/@dprint/typescript/plugin.wasm",
    "node_modules/@dprint/json/plugin.wasm"
  ]
}
