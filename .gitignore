# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# run-splotch driver screenshots (.claude/skills/run-splotch)
/screenshots/

# Performance profiling captures (npm run perf:web) — local artifacts.
/perf-profiles/

# Lighthouse audit reports (.claude/skills/lighthouse-audit) — attach to the PR, don't commit.
/lighthouse-reports/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.*
!.env.example

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and not Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# vuepress v2.x temp and cache directory
.temp
.cache

# Sveltekit cache directory
.svelte-kit/

# vitepress build output
**/.vitepress/dist

# vitepress cache directory
**/.vitepress/cache

# Docusaurus cache and generated files
.docusaurus

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Firebase cache directory
.firebase/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite logs files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# PWA
dev-dist/
sw.js
sw.js.map
workbox-*.js
workbox-*.js.map

## Mac
.DS_Store
build/
# The `build` skill (source + its ruler-generated copies, ADR-0058) must dodge
# the blanket build/ ignore above.
!.ruler/skills/build/
!.claude/skills/build/
!.agents/skills/build/
.netlify/

# Netlify CLI's Deno edge-bundler lockfile — no edge functions in this project, regenerable
deno.lock

# android studio
android/.idea

# iOS personal signing (DEVELOPMENT_TEAM) — included by ios/debug.xcconfig, passed to ios:archive
ios/local.xcconfig

# Maestro smoke-test screenshots (npm run test:android) — takeScreenshot writes
# these relative to the repo root (Maestro's cwd); keep them out of the tree.
/.maestro/screenshots/

# Red-team AI safety fixtures (ADR-0023). Only encrypted/*.enc is committed;
# the plaintext sources, decrypted copies, and run outputs stay local.
# Anchored at web/ since the app moved into that subdirectory (ADR-0024).
/web/tests/redteam/source/
/web/tests/redteam/decrypted/
/web/tests/redteam/output/

# Image-model eval harness (scripts/model-eval-*). The local input corpus is
# regenerable (npm run model-eval:fixtures) and run outputs are large, so both stay
# local — but the Gemini-authored gen__* inputs (not reproducible) and the committed
# reference report (web/tests/model-eval/reference/) are kept in git.
/web/tests/model-eval/inputs/*
!/web/tests/model-eval/inputs/gen__*
/web/tests/model-eval/output/
# Scratch dir for ad-hoc eval debugging.
/.eval-tmp/

# Coloring-page fill candidates + overlays generated by tools/asset-gen/bin/gen-coloring-fills.mjs
# for review; the shipped colored fills live next to their source pages instead. The generators
# write to the repo root (lib/paths.mjs SAMPLES_DIR/SAMPLES_DARK_DIR); unanchored so ad-hoc
# scratch copies under tools/asset-gen/ stay ignored too.
.coloring-samples/
.coloring-samples-dark/
