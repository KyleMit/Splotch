@@ -167,6 +170,7 @@
     "gen:coloring-punch": "Re-derive the shipped fills-only .light/.night.webp from the raw fills in tools/asset-gen/fill-src/ by punching their outlines out (line art as mask). Deterministic, no API key/network (-- page-or-category… to filter)",
     "gen:coloring-thumbs": "Regenerate the .thumb.webp grid thumbnails beside every coloring cover/page for the picker (-- category… to filter)",
     "gen:contact-sheet": "Build a self-contained HTML contact sheet of ONE coloring category — light + night fills side by side with outline-keep scores — to review/publish as an Artifact (-- category[/page[-orient]], --source shipped|samples, --out FILE)",
+    "gen:assets:manifest": "Rewrite tools/asset-gen/asset-manifest.sha256 (sha256 per committed art asset: coloring pages, style covers, fill-src raws) so binary asset changes review as text diffs; verified in CI by check:assets:manifest",
     "gen:shots": "Regenerate the store screenshots + feature graphic for both stores into store-assets/ (Playwright)",
     "cap:sync": "build:cap + copy web assets & plugins into the native projects",
     "cap:android": "cap:sync + open the Android project in Android Studio",
