diff --git a/tools/asset-gen/gen-coloring-composite.mjs b/tools/asset-gen/gen-coloring-composite.mjs
new file mode 100644
index 0000000..1ae87db
--- /dev/null
+++ b/tools/asset-gen/gen-coloring-composite.mjs
@@ -0,0 +1,211 @@
+// Render what the canvas ACTUALLY shows for a coloring page, in both themes:
+// the light composite (fill under the multiplied PEN outline on light paper)
+// and the night composite (lib/night-composite.mjs — chalk-punched fill with
+// the chalk's negation screened over dark paper). The contact sheet's Combined
+// view simulates the same thing in-browser; this writes it to disk so any
+// "should I override this gate?" call — a candidate that failed scoreLineColor
+// or judgeNightEyes, a raw that failed the drift audit — can be judged on the
+// final render instead of the raw fill (see pipeline.md: vehicles/train-wide
+// held lineW 51–105 for ~27 attempts while its composite rendered perfectly).
+// Deterministic sharp only — no network, no GEMINI_API_KEY.
+//
+//   npm run gen:coloring-composite -- vehicles/train-wide       one page, shipped assets
+//   npm run gen:coloring-composite -- farm                      a whole category
+//   npm run gen:coloring-composite -- vehicles/train-wide --source raw      the committed lined raws in fill-src/
+//   npm run gen:coloring-composite -- vehicles/train-wide --source samples  fresh candidates in .coloring-samples*/
+//
+// Outputs land in .coloring-samples/composite/ (gitignored; --out DIR to move).
+import { parseArgs } from 'node:util';
+import { readFile, readdir, mkdir, writeFile } from 'node:fs/promises';
+import { glob } from 'node:fs/promises';
+import { existsSync, statSync } from 'node:fs';
+import { join, relative, dirname } from 'node:path';
+import sharp from 'sharp';
+import {
+  REPO_ROOT,
+  COLORING_DIR,
+  FILL_SRC_DIR,
+  SAMPLES_DIR,
+  SAMPLES_DARK_DIR,
+  fail,
+} from './lib/paths.mjs';
+import { compositeNight } from './lib/night-composite.mjs';
+
+const PUNCH_LUMA = 150; // lib/punch-fill.mjs OUTLINE_LUMA_THRESHOLD
+const PAPER_LIGHT = [0xfc, 0xfb, 0xf8]; // app.css --paper (light)
+
+const { values, positionals } = parseArgs({
+  allowPositionals: true,
+  options: {
+    source: { type: 'string', default: 'shipped' },
+    out: { type: 'string' },
+  },
+});
+const SOURCES = ['shipped', 'raw', 'samples'];
+if (!SOURCES.includes(values.source))
+  fail(`--source must be one of ${SOURCES.join('|')} (got "${values.source}")`);
+
+// The light-mode canvas render: the fill multiplied under the pen outline on
+// light paper (app.css --lineart-blend: multiply). Shipped fills are already
+// fills-only and draw as-is (punch: false); lined raws/candidates get the same
+// binary punch the shipped derivation applies, so the fill's own outline copy
+// isn't doubled under the overlay.
+async function compositeLight(fillBuf, penBuf, { punch }) {
+  const {
+    data: fill,
+    info: { width, height },
+  } = await sharp(fillBuf).removeAlpha().raw().toBuffer({ resolveWithObject: true });
+  const { data: ink } = await sharp(penBuf)
+    .grayscale()
+    .resize(width, height, { fit: 'fill' })
+    .raw()
+    .toBuffer({ resolveWithObject: true });
+  const out = Buffer.alloc(width * height * 3);
+  for (let p = 0, i = 0; p < width * height; p++, i += 3) {
+    const punched = punch && ink[p] < PUNCH_LUMA;
+    for (let c = 0; c < 3; c++) {
+      const base = punched ? PAPER_LIGHT[c] : fill[i + c];
+      out[i + c] = (base * ink[p]) / 255;
+    }
+  }
+  return sharp(out, { raw: { width, height, channels: 3 } })
+    .png()
+    .toBuffer();
+}
+
+// The dark-mode render of a SHIPPED night fill: already fills-only (outline
+// pixels inpainted — docs/inpainted-fill-punch.md), so no punch; just the
+// chalk's negation screened on top, exactly as the canvas blends the themed
+// overlay. Lined raws/candidates go through lib/night-composite.mjs instead,
+// byte-identical to the gates' simulated composite.
+async function compositeNightShipped(fillBuf, chalkBuf) {
+  const {
+    data: fill,
+    info: { width, height },
+  } = await sharp(fillBuf).removeAlpha().raw().toBuffer({ resolveWithObject: true });
+  const { data: ink } = await sharp(chalkBuf)
+    .grayscale()
+    .resize(width, height, { fit: 'fill' })
+    .raw()
+    .toBuffer({ resolveWithObject: true });
+  const out = Buffer.alloc(width * height * 3);
+  for (let p = 0, i = 0; p < width * height; p++, i += 3) {
+    for (let c = 0; c < 3; c++) {
+      out[i + c] = 255 - ((255 - fill[i + c]) * ink[p]) / 255;
+    }
+  }
+  return sharp(out, { raw: { width, height, channels: 3 } })
+    .png()
+    .toBuffer();
+}
+
+// Resolve args to source line-art pages, same shapes as the drift audit: a
+// page ("vehicles/train-wide"), a category dir ("farm"), or nothing (all).
+async function pagesUnder(sub = '') {
+  const cwd = sub ? join(COLORING_DIR, sub) : COLORING_DIR;
+  const out = [];
+  for await (const entry of glob('**/*-{tall,wide}.outline.webp', { cwd }))
+    out.push(join(cwd, entry));
+  return out;
+}
+async function resolveArg(arg) {
+  if (arg.endsWith('.webp')) return [join(COLORING_DIR, arg)];
+  const asFile = join(COLORING_DIR, `${arg}.outline.webp`);
+  if (existsSync(asFile)) return [asFile];
+  const asDir = join(COLORING_DIR, arg);
+  if (existsSync(asDir) && statSync(asDir).isDirectory()) return pagesUnder(arg);
+  return [asFile];
+}
+
+const pages = (
+  positionals.length ? (await Promise.all(positionals.map(resolveArg))).flat() : await pagesUnder()
+).sort();
+if (!pages.length) fail('No pages matched.');
+
+const outDir = values.out ?? join(SAMPLES_DIR, 'composite');
+await mkdir(outDir, { recursive: true });
+
+// Candidate takes in the scratch dirs, as the generators name them:
+// night — .coloring-samples-dark/{cat}/{page}.webp or {page}.sample-N.webp
+// (never the *.input.webp montage aid); light — .coloring-samples/{cat}/{page}/sample-N.webp.
+async function nightCandidates(rel) {
+  const dir = join(SAMPLES_DARK_DIR, dirname(rel));
+  const base = rel.split('/').pop();
+  if (!existsSync(dir)) return [];
+  const takes = (await readdir(dir)).filter(
+    (f) => f === `${base}.webp` || (f.startsWith(`${base}.sample-`) && f.endsWith('.webp'))
+  );
+  return takes.map((f) => ({
+    path: join(dir, f),
+    tag: f.match(/(\.sample-\d+)\.webp$/)?.[1] ?? '.take',
+  }));
+}
+async function lightCandidates(rel) {
+  const dir = join(SAMPLES_DIR, rel);
+  if (!existsSync(dir)) return [];
+  const takes = (await readdir(dir)).filter((f) => /^sample-\d+\.webp$/.test(f));
+  return takes.map((f) => ({ path: join(dir, f), tag: `.${f.replace(/\.webp$/, '')}` }));
+}
+
+let written = 0;
+let skipped = 0;
+async function emit(name, bufP) {
+  const out = join(outDir, name);
+  await writeFile(out, await bufP);
+  written++;
+  console.log(`  -> ${relative(REPO_ROOT, out)}`);
+}
+function skip(what) {
+  skipped++;
+  console.log(`  (no ${what})`);
+}
+
+for (const page of pages) {
+  if (!existsSync(page))
+    fail(`No such page: ${relative(COLORING_DIR, page).replace(/\.outline\.webp$/, '')}`);
+  const rel = relative(COLORING_DIR, page).replace(/\.outline\.webp$/, '');
+  const flat = rel.replace(/\//g, '-');
+  const pen = await readFile(page);
+  const chalkPath = page.replace(/\.outline\.webp$/, '.chalk.webp');
+  const chalk = existsSync(chalkPath) ? await readFile(chalkPath) : pen;
+  const chalkNote = existsSync(chalkPath) ? 'chalk' : 'no chalk (pen)';
+  console.log(`${rel}  [${values.source}, night line art: ${chalkNote}]`);
+
+  if (values.source === 'shipped') {
+    const light = join(COLORING_DIR, `${rel}.light.webp`);
+    const night = join(COLORING_DIR, `${rel}.night.webp`);
+    if (existsSync(light))
+      await emit(`${flat}.light.png`, compositeLight(await readFile(light), pen, { punch: false }));
+    else skip('shipped light fill');
+    if (existsSync(night))
+      await emit(`${flat}.night.png`, compositeNightShipped(await readFile(night), chalk));
+    else skip('shipped night fill');
+  } else if (values.source === 'raw') {
+    const light = join(FILL_SRC_DIR, `${rel}.light.raw.webp`);
+    const night = join(FILL_SRC_DIR, `${rel}.night.raw.webp`);
+    if (existsSync(light))
+      await emit(
+        `${flat}.raw.light.png`,
+        compositeLight(await readFile(light), pen, { punch: true })
+      );
+    else skip('light raw');
+    if (existsSync(night))
+      await emit(`${flat}.raw.night.png`, compositeNight(await readFile(night), chalk));
+    else skip('night raw');
+  } else {
+    const lights = await lightCandidates(rel);
+    const nights = await nightCandidates(rel);
+    if (!lights.length && !nights.length) skip('candidates in scratch');
+    for (const c of lights)
+      await emit(
+        `${flat}${c.tag}.light.png`,
+        compositeLight(await readFile(c.path), pen, { punch: true })
+      );
+    for (const c of nights)
+      await emit(`${flat}${c.tag}.night.png`, compositeNight(await readFile(c.path), chalk));
+  }
+}
+
+console.log(
+  `Done. ${written} composite(s) written${skipped ? `, ${skipped} side(s) skipped` : ''}.`
+);
