{
  "name": "splotch",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "icons:types": "node scripts/generate-icon-names.mjs",
    "predev": "npm run icons:types",
    "prebuild": "npm run icons:types",
    "prebuild:cap": "npm run icons:types",
    "dev": "vite dev",
    "dev:cap": "cross-env CAPACITOR=true vite dev --host",
    "dev:netlify": "netlify dev",
    "build": "vite build",
    "build:cap": "cross-env CAPACITOR=true vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build:cap && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios",
    "android:apk": "npm run cap:sync && cd android && .\\gradlew :app:assembleDebug",
    "android:run": "npm run cap:sync && cd android && .\\gradlew :app:installDebug",
    "android:emulator": "npm run cap:sync && cap run android --target Pixel_7_Pro_API_33",
    "android:live": "cap run android --target Pixel_7_Pro_API_33 --live-reload --port 5173",
    "android:bundle": "npm run cap:sync && cd android && .\\gradlew :app:bundleRelease",
    "android:verify": "\"%JAVA_HOME%\\bin\\jarsigner\" -verify android/app/build/outputs/bundle/release/app-release.aab",
    "android:clean": "cd android && .\\gradlew clean",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "cross-env SLOWMO=500 playwright test --headed",
    "test:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-netlify": "^4.3.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "cross-env": "^10.1.0",
    "patch-package": "^8.0.1",
    "sharp": "^0.34.5",
    "svelte": "^5.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor-community/media": "^9.1.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@fontsource-variable/quicksand": "^5.2.10",
    "@google/genai": "^2.6.0",
    "@netlify/blobs": "^10.7.8",
    "@sveltejs/adapter-static": "^3.0.10",
    "idb": "^8.0.3"
  }
}
