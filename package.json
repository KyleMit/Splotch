{
  "name": "splotch",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "icons:types": "node scripts/generate-icon-names.mjs",
    "releases:gen": "node scripts/generate-releases.mjs",
    "check:assets": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/check-assets.mjs",
    "prerelease": "npm run check:assets",
    "release": "node scripts/release.mjs",
    "predev": "svelte-kit sync",
    "prebuild": "svelte-kit sync && npm run icons:types && npm run releases:gen",
    "prebuild:cap": "svelte-kit sync && npm run icons:types && npm run releases:gen",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "dev:kill": "npx kill-port 5173",
    "dev:host": "vite dev --host",
    "dev:cap": "cross-env CAPACITOR=true vite dev --host",
    "dev:netlify": "netlify dev",
    "build": "vite build",
    "build:cap": "cross-env CAPACITOR=true vite build && node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/strip-native-assets.mjs",
    "preview": "vite preview",
    "cap:sync": "npm run build:cap && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios",
    "android:apk": "npm run cap:sync && cd android && .\\gradlew :app:assembleDebug",
    "android:run": "npm run cap:sync && cd android && .\\gradlew :app:installDebug",
    "android:emulator": "npm run cap:sync && cap run android --target Pixel_7_Pro_API_33",
    "android:live": "cap run android --target Pixel_7_Pro_API_33 --live-reload --port 5173",
    "android:bundle": "npm run cap:sync && cd android && .\\gradlew :app:bundleRelease",
    "android:verify": "node scripts/android-verify.mjs",
    "android:open": "start \"\" \"android\\app\\build\\outputs\\bundle\\release\"",
    "android:clean": "cd android && .\\gradlew clean",
    "adb:devices": "adb devices",
    "adb:reverse": "adb reverse tcp:5173 tcp:5173",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install",
    "test:e2e:update": "npx update-browserslist-db@latest",
    "test:android": "node scripts/android-emulator-smoke.mjs",
    "test:android:device": "maestro test .maestro/smoke.yaml",
    "test:ui": "playwright test --ui",
    "test:headed": "cross-env SLOWMO=500 playwright test --headed",
    "test:debug": "playwright test --debug",
    "gen:large-image": "node scripts/gen-large-image.mjs"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-netlify": "^4.3.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "capacitor-set-version": "^2.2.0",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.10.1",
    "marked": "^18.0.4",
    "patch-package": "^8.0.1",
    "sharp": "^0.34.5",
    "svelte": "^5.0.0",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor-community/media": "^9.1.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@fontsource-variable/quicksand": "^5.2.10",
    "@google/genai": "^2.6.0",
    "@netlify/blobs": "^10.7.8",
    "@sveltejs/adapter-static": "^3.0.10",
    "idb": "^8.0.3"
  }
}
