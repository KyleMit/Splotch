# Copy this file to .env (gitignored) before running npm run test:e2e.
#
# ALLOWED_TOKENS_LIST is the comma-separated list of managed access tokens
# accepted by /api/generate-image. The value below is the test token used by
# the throttle spec (tests/generate-image.spec.ts) — it is not a real secret.
ALLOWED_TOKENS_LIST="abc,daycare-club"

# Real Gemini API key — only needed if you want the AI generation flow to
# actually call Gemini during local testing. Tests that exercise generation use
# BYOK (apiKey field) or mock the endpoint, so this is optional for the E2E suite.
# GEMINI_API_KEY=
GEMINI_API_KEY=replace
ADMIN_ACCESS_TOKEN=replace

# In-app feedback → GitHub issue (POST /api/report). GITHUB_ISSUE_TOKEN is a
# fine-grained Personal Access Token scoped to "Issues: Read and write" on the
# target repo only — it is read server-side via $env/dynamic/private and never
# shipped to the client. Without it, /api/report returns a graceful 503.
#
# One-time setup:
#   1. Create the token — GitHub → Settings → Developer settings →
#      Fine-grained tokens → Generate new token.
#        - Resource owner: the account/org that owns the repo
#        - Repository access: Only select repositories → KyleMit/Splotch
#        - Permissions: Repository permissions → Issues → Read and write
#          (nothing else)
#      Note the expiry (fine-grained PATs last at most 1 year — rotate before it
#      lapses, or reporting falls back to the 503 above).
#   2. Set it in production — Netlify → Site settings → Environment variables →
#      add GITHUB_ISSUE_TOKEN = <the token>. Redeploy. For local dev, put it in
#      web/.env (gitignored) as below.
#
# GITHUB_ISSUE_REPO overrides the target repo (default: KyleMit/Splotch).
# GITHUB_ISSUE_TOKEN=
# GITHUB_ISSUE_REPO=KyleMit/Splotch

# Passphrase for the red-team AI-safety fixtures (ADR-0023). Encrypts/decrypts
# the crude probe drawings under tests/redteam/ so no viewable PNG of unsafe
# imagery lands in the tree. Share it out-of-band; never commit the real value.
# Used by: npm run redteam:encrypt / redteam:decrypt / redteam.
REDTEAM_FIXTURE_KEY=replace
