{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-edited-file.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/cloud-branch-preview.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(node scripts/*)",
      "Bash(node scripts/**)",
      "Bash(node --check *)",
      "Bash(node --input-type=module -e *)",

      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show *)",
      "Bash(git branch*)",
      "Bash(git stash list)",
      "Bash(git rm *)",

      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(sed *)",
      "Bash(jq *)",

      "Bash(curl -s * http://localhost:*)",
      "Bash(curl -s -i * http://localhost:*)",
      "Bash(curl -s -o /dev/null * http://localhost:*)",

      "Bash(adb *)",
      "Bash(xcrun simctl *)",
      "Bash(xcode-select -p)",
      "Bash(xcodebuild -version)",
      "Bash(pod --version)",
      "Bash(ruby --version)",
      "Bash(afplay *)",

      "Skill(update-config)",
      "Skill(update-config:*)",

      "Read(//tmp/**)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard origin*)",
      "Bash(git rebase*)",
      "Bash(git clean*)",
      "Bash(git branch -D*)",
      "Bash(rm -rf /*)"
    ]
  }
}
